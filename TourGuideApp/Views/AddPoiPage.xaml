<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:lang="clr-namespace:TourGuideApp.Resources.Languages"
             x:Class="TourGuideApp.Views.AddPoiPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#FAF7F2">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <Label Text="{x:Static lang:AppLang.AddPoiTitle}" FontSize="22" FontAttributes="Bold" TextColor="#4A3A31"/>

            <Frame CornerRadius="16" HeightRequest="220" BackgroundColor="#E8E0D5" HasShadow="False" Padding="0" IsClippedToBounds="True" BorderColor="Transparent">
                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnSelectImageTapped"/>
                </Frame.GestureRecognizers>

                <Grid>
                    <Image x:Name="imgPreview" Aspect="AspectFill" IsVisible="False"/>

                    <VerticalStackLayout x:Name="pnlImagePlaceholder" HorizontalOptions="Center" VerticalOptions="Center" Spacing="10">
                        <Label Text="📷" FontSize="50" HorizontalOptions="Center"/>
                        <Label Text="{x:Static lang:AppLang.AddPoiImagePrompt}" FontSize="14" TextColor="#8D7A6D" FontAttributes="Bold" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Grid>
            </Frame>

            <Frame CornerRadius="12" Padding="15" HasShadow="True" BorderColor="Transparent" BackgroundColor="White">
                <VerticalStackLayout Spacing="15">
                    <VerticalStackLayout Spacing="5">
                        <Label Text="{x:Static lang:AppLang.AddPoiName}" FontSize="14" FontAttributes="Bold" TextColor="#8D7A6D"/>
                        <Entry x:Name="txtName" Placeholder="{x:Static lang:AppLang.AddPoiNamePlaceholder}" TextColor="#4A3A31" BackgroundColor="#FAF7F2" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="5">
                        <Label Text="{x:Static lang:AppLang.AddPoiDesc}" FontSize="14" FontAttributes="Bold" TextColor="#8D7A6D"/>
                        <Editor x:Name="txtDescription" Placeholder="{x:Static lang:AppLang.AddPoiDescPlaceholder}" HeightRequest="100" TextColor="#4A3A31" BackgroundColor="#FAF7F2"/>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <Frame CornerRadius="12" Padding="15" HasShadow="True" BorderColor="Transparent" BackgroundColor="White">
                <VerticalStackLayout Spacing="15">
                    <Button Text="{x:Static lang:AppLang.AddPoiGetLocation}" 
                BackgroundColor="#E8E0D5" TextColor="#C0502E" FontAttributes="Bold" CornerRadius="8"
                Clicked="OnGetLocationClicked"/>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <VerticalStackLayout Grid.Column="0" Spacing="5">
                            <Label Text="{x:Static lang:AppLang.AddPoiLat}" FontSize="12" FontAttributes="Bold" TextColor="#8D7A6D"/>
                            <Entry x:Name="txtLat" Placeholder="0.000000" 
                       Keyboard="Text"
                       TextColor="#4A3A31" BackgroundColor="#FAF7F2" FontSize="13"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="5">
                            <Label Text="{x:Static lang:AppLang.AddPoiLng}" FontSize="12" FontAttributes="Bold" TextColor="#8D7A6D"/>
                            <Entry x:Name="txtLng" Placeholder="0.000000" 
                       Keyboard="Text"
                       TextColor="#4A3A31" BackgroundColor="#FAF7F2" FontSize="13"/>
                        </VerticalStackLayout>
                    </Grid>

                    <VerticalStackLayout Spacing="5" Margin="0,5,0,0">
                        <Label Text="{x:Static lang:AppLang.AddPoiRadius}" FontSize="12" FontAttributes="Bold" TextColor="#8D7A6D"/>
                        <Entry Text="50" IsReadOnly="True" 
                   TextColor="#7F8C8D" BackgroundColor="#F2F2F2" 
                   FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <Button Text="{x:Static lang:AppLang.AddPoiSubmit}" 
                    FontAttributes="Bold" FontSize="16" HeightRequest="55"
                    BackgroundColor="#27AE60" TextColor="White" CornerRadius="27"
                    Margin="0,10,0,20"
                    Shadow="{Shadow Brush=Black, Offset='0,4', Opacity=0.2, Radius=5}"
                    Clicked="OnSubmitClicked"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>