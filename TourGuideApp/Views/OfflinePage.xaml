<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:lang="clr-namespace:TourGuideApp.Resources.Languages"
             x:Class="TourGuideApp.Views.OfflinePage"
             BackgroundColor="#FAF7F2"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto, *">

        <Frame Grid.Row="0" WidthRequest="40" HeightRequest="40" CornerRadius="20" BackgroundColor="White" Padding="0" HasShadow="True" HorizontalOptions="Start" Margin="20,20,0,0">
            <Frame.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnBackTapped"/>
            </Frame.GestureRecognizers>
            <Label Text="❮" FontSize="18" FontAttributes="Bold" TextColor="#4A3A31" HorizontalOptions="Center" VerticalOptions="Center" Margin="0,0,2,0"/>
        </Frame>

        <VerticalStackLayout Grid.Row="1" Padding="20" Spacing="20" VerticalOptions="Center">

            <Image Source="icon_offline_download.png" WidthRequest="120" HeightRequest="120" HorizontalOptions="Center"/>

            <Label Text="{x:Static lang:AppLang.OfflineTitle}" FontSize="24" FontAttributes="Bold" TextColor="#4A3A31" HorizontalOptions="Center"/>
            <Label Text="{x:Static lang:AppLang.OfflineDesc}" 
                   FontSize="14" TextColor="#8D7A6D" HorizontalTextAlignment="Center" Margin="0,0,0,20"/>

            <Frame BackgroundColor="White" CornerRadius="16" HasShadow="True" Padding="20" BorderColor="Transparent">
                <VerticalStackLayout Spacing="15">

                    <Grid ColumnDefinitions="*, Auto">
                        <VerticalStackLayout Grid.Column="0">
                            <Label Text="{x:Static lang:AppLang.OfflineCity}" FontSize="18" FontAttributes="Bold" TextColor="#2C3E50"/>
                            <Label Text="{x:Static lang:AppLang.OfflineSize}" FontSize="13" TextColor="#7F8C8D"/>
                        </VerticalStackLayout>
                        <Label x:Name="lblStatus" Grid.Column="1" Text="{x:Static lang:AppLang.OfflineStatusPending}" TextColor="#E74C3C" FontAttributes="Bold" VerticalOptions="Center"/>
                    </Grid>

                    <ActivityIndicator x:Name="loadingIndicator" IsRunning="False" IsVisible="False" Color="#C0502E" HorizontalOptions="Center"/>

                    <Button x:Name="btnDownload" Text="{x:Static lang:AppLang.OfflineBtnDownload}" 
                            BackgroundColor="#27AE60" TextColor="White" FontAttributes="Bold" 
                            CornerRadius="25" HeightRequest="50" 
                            Clicked="OnDownloadClicked"/>
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </Grid>
</ContentPage>