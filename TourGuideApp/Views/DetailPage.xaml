<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="TourGuideApp.Views.DetailPage"
    BackgroundColor="#FAF7F2">
    
    <VerticalStackLayout Grid.Row="0" Margin="0,0,0,20" Spacing="10" Padding="20">

        <!-- Name -->
        <Label Text="{Binding Name}"
           FontSize="24"
           FontAttributes="Bold"/>


        <!-- Hàng icon -->
        <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">

            <!-- ▶ bên trái -->
            <Frame Grid.Column="0"
           WidthRequest="40" HeightRequest="40"
           CornerRadius="20"
           BackgroundColor="#C0502E"
           HasShadow="False"
           Padding="0">
                <Label Text="▶"
               FontSize="18"
               TextColor="White"
               HorizontalOptions="Center"
               VerticalOptions="Center"/>
            </Frame>

            <!-- ❤️ yêu thích -->
            <Frame Grid.Column="3"
           WidthRequest="40" HeightRequest="40"
           CornerRadius="20"
           BackgroundColor="#C0502E"
           HasShadow="False"
           Padding="0">
                <Label Text="❤︎⁠"
               FontSize="18"
               TextColor="White"
               HorizontalOptions="Center"
               VerticalOptions="Center"/>
            </Frame>

        </Grid>

        <!-- Description -->
        <Label Text="{Binding Description}"
           FontSize="18"/>

    </VerticalStackLayout>

</ContentPage>