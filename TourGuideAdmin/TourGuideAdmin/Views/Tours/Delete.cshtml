@model TourGuideAdmin.Models.Tour

@{
    ViewData["Title"] = "Xóa Tour";
}

<div class="qr-page-header" data-watermark="DELETE" style="background:linear-gradient(135deg,#3a1a0e 0%,#5a2010 60%,#c0392b 100%);">
    <h2>🗑️ Xóa Tour</h2>
    <p>Bạn có chắc chắn muốn xóa tour này? Hành động không thể hoàn tác.</p>
</div>

<div class="qr-card" style="border-color:#f5c6c0;">
    <div style="background:#fdecea;border:1px solid #f5c6c0;color:#962d22;padding:14px 18px;border-radius:10px;margin-bottom:20px;font-weight:600;">
        ⚠️ Cảnh báo: Xóa tour có thể ảnh hưởng đến các địa điểm (POI) đang thuộc tour này.
    </div>

    @if (!string.IsNullOrEmpty(Model.ImageUrl))
    {
        <img src="~/images/tours/@Model.ImageUrl" class="card-img-top" alt="@Model.Name_VI" style="max-width:500px;width:100%;border-radius:12px;border:1px solid var(--qr-border);" />
    }
    else
    {
        <div class="bg-light text-center d-flex align-items-center justify-content-center" style="height: 250px;">
            <span class="text-muted">📷 Chưa có hình ảnh</span>
        </div>
    }

    <div class="qr-info-row"><div class="lbl">Mã ID</div><div class="val">#@Model.Id</div></div>
    <div class="qr-info-row"><div class="lbl">Tên Tour</div><div class="val" style="font-weight:600;">@Model.Name_VI</div></div>
    <div class="qr-info-row"><div class="lbl">Thời gian</div><div class="val">@Model.EstimatedTime</div></div>

    <form asp-action="Delete" class="qr-form" style="margin-top:20px;">
        <input type="hidden" asp-for="Id" />
        <div class="qr-form-actions">
            <button type="submit" value="Delete" class="btn-qr-danger">🗑️ Xác nhận xóa</button>
            <a asp-action="Index" class="btn-qr-outline">← Hủy</a>
        </div>
    </form>
</div>