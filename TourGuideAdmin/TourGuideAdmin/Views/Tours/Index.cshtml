@model IEnumerable<TourGuideAdmin.Models.Tour>

@{
    ViewData["Title"] = "Quản lý Tour";
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger" style="border-radius:12px;border:none;">@TempData["Error"]</div>
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success" style="border-radius:12px;border:none;">@TempData["Success"]</div>
}

<div class="qr-page-header" data-watermark="TOUR">
    <h2>🗺️ Quản lý Tour</h2>
    <p>Tạo, chỉnh sửa và sắp xếp các tour tham quan</p>
    <span class="qr-stat-badge">🛣️ Tổng số: @Model.Count() tour</span>
</div>

<form asp-action="Index" method="get" class="filter-bar">
    <input type="text" name="searchString" class="form-control" style="flex:1;min-width:240px;"
           placeholder="🔍 Tìm theo tên tour..."
           value="@Context.Request.Query["searchString"]" />
    <button type="submit" class="btn-qr">Tìm kiếm</button>
    <a asp-action="Index" class="btn-qr-outline">Đặt lại</a>
    <a asp-action="Create" class="btn-qr ms-auto">+ Thêm tour</a>
</form>

<div class="qr-card p-0" style="overflow:hidden;">
    <table class="qr-table">
        <thead>
            <tr>
                <th width="10%">ID</th>
                <th width="45%">Tên Tour (VI)</th>
                <th width="25%">Hình ảnh</th>
                <th class="text-center" width="20%">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><span class="qr-stat-badge" style="background:var(--qr-muted);color:var(--qr-text);border-color:var(--qr-border);margin:0;">#@item.Id</span></td>
                    <td style="font-weight:600;color:var(--qr-accent-dark);">@item.Name_VI</td>
                    <td>
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <span style="color:#2e7d32;font-size:.85rem;">✅ Có hình ảnh</span>
                        }
                        else
                        {
                            <span style="color:var(--qr-sub);font-size:.85rem;font-style:italic;">Chưa có hình</span>
                        }
                    </td>
                    <td class="text-center">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn-qr-outline" style="padding:4px 10px;font-size:.8rem;">✏️ Sửa</a>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn-qr-outline" style="padding:4px 10px;font-size:.8rem;">📄 Chi tiết</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn-qr-outline" style="padding:4px 10px;font-size:.8rem;border-color:#c0392b;color:#c0392b;">🗑️ Xóa</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
