@model TourGuideAdmin.Models.POI

@{
    Layout = null;
    ViewData["Title"] = $"In QR — {Model.Name_VI}";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"]</title>
    <style>
        @@page { size: A4; margin: 20mm; }
        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 90vh;
            margin: 0;
        }
        .card {
            border: 2px dashed #999;
            padding: 24px 32px;
            text-align: center;
            max-width: 500px;
        }
        .card img { width: 320px; height: 320px; }
        .card h1 { font-size: 28px; margin: 16px 0 8px; color: #1a3a5c; }
        .card .sub { color: #666; font-size: 14px; margin-bottom: 16px; }
        .card .hint { font-size: 13px; color: #444; margin-top: 12px; }
        .toolbar {
            margin-top: 20px;
            text-align: center;
        }
        .toolbar button {
            padding: 8px 20px;
            font-size: 14px;
            cursor: pointer;
            background: #1a73e8;
            color: white;
            border: 0;
            border-radius: 4px;
        }
        @@media print {
            .toolbar { display: none; }
            .card { border-color: #ccc; }
        }
    </style>
</head>
<body>
    <div class="card">
        <img src="@Url.Action("Image", new { id = Model.Id, size = 12 })"
             alt="QR @Model.Name_VI" />
        <h1>@Model.Name_VI</h1>
        @if (!string.IsNullOrEmpty(Model.Name_EN))
        {
            <div class="sub">@Model.Name_EN</div>
        }
        <div class="hint">📱 Quét mã QR bằng ứng dụng TourGuide GPS để nghe thuyết minh</div>
    </div>
    <div class="toolbar">
        <button onclick="window.print()">🖨️ In ngay (Ctrl+P)</button>
    </div>
</body>
</html>
