@model IEnumerable<TourGuideAdmin.Models.User>

@{
    ViewData["Title"] = "Quản lý Tài khoản";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 style="color: #C0502E; font-weight: bold;">👥 Quản lý Người Dùng</h2>
        <span class="badge bg-info text-dark fs-6">Tổng cộng: @Model.Count() tài khoản</span>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            ✅ @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            ❌ @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="table-responsive bg-white rounded shadow-sm">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th class="ps-4">ID</th>
                    <th>Tên đăng nhập</th>
                    <th>Mật khẩu</th>
                    <th>Vai trò</th>
                    <th class="text-center">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4 fw-bold text-muted">#@item.Id</td>
                        <td class="fw-bold" style="color: #4A3A31;">@item.Username</td>

                        <td>
                            <span class="text-secondary" style="letter-spacing: 2px;">••••••••</span>
                        </td>

                        <td>
                            @if (item.Role == 1)
                            {
                                <span class="badge bg-danger">👑 Admin</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">🎒 Khách vãng lai</span>
                            }
                        </td>

                        <td class="text-center">
                            @if (item.Role != 1)
                            {
                                <form asp-action="Delete" method="post" class="d-inline"
                                      onsubmit="return confirm('Sếp có chắc chắn muốn xóa vĩnh viễn tài khoản [@item.Username] không? Mọi dữ liệu địa điểm của người này có thể trở thành Vô Danh đấy!');">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3">
                                        🗑️ Xóa Tài Khoản
                                    </button>
                                </form>
                            }
                            else
                            {
                                <button class="btn btn-outline-secondary btn-sm rounded-pill px-3" disabled>
                                    🛡️ Bất tử
                                </button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>