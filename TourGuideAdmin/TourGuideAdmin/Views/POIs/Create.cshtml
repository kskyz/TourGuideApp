@model TourGuideAdmin.Models.POI

@{
    ViewData["Title"] = "Thêm Địa điểm";
}

<div class="qr-page-header" data-watermark="POI">
    <h2>📍 Thêm Địa điểm mới</h2>
    <p>Điền thông tin để tạo một điểm tham quan mới</p>
</div>

<div class="qr-card">
    <form asp-action="Create" enctype="multipart/form-data" class="qr-form">
        <div asp-validation-summary="ModelOnly" class="qr-validation"></div>

        <div class="qr-form-row">
            <div class="qr-field">
                <label asp-for="TourId">Thuộc Tour (Mã ID) <span class="req">*</span></label>
                <input asp-for="TourId" class="form-control" placeholder="VD: 1" required />
                <span asp-validation-for="TourId" class="qr-validation"></span>
            </div>
            <div class="qr-field">
                <label asp-for="Name_VI">Tên Địa Điểm (Tiếng Việt) <span class="req">*</span></label>
                <input asp-for="Name_VI" class="form-control" placeholder="VD: Dinh Độc Lập" required />
                <span asp-validation-for="Name_VI" class="qr-validation"></span>
            </div>
        </div>

        <div class="qr-form-row">
            <div class="qr-field">
                <label asp-for="Latitude">Vĩ độ (Latitude)</label>
                <input asp-for="Latitude" class="form-control" placeholder="VD: 10.7769" />
            </div>
            <div class="qr-field">
                <label asp-for="Longitude">Kinh độ (Longitude)</label>
                <input asp-for="Longitude" class="form-control" placeholder="VD: 106.6951" />
            </div>
        </div>

        <div class="qr-form-row">
            <div class="qr-field">
                <label asp-for="TriggerRadius">Bán kính kích hoạt (m)</label>
                <input asp-for="TriggerRadius" class="form-control" value="50" />
                <div class="hint">Khoảng cách (mét) để tự động phát thuyết minh khi người dùng đến gần.</div>
            </div>
            <div class="qr-field">
                <label asp-for="Priority">Độ ưu tiên</label>
                <input asp-for="Priority" class="form-control" value="1" />
            </div>
        </div>

        <div class="qr-field">
            <label class="qr-check">
                <input class="form-check-input" asp-for="IsFavorite" />
                ❤️ Đánh dấu là Địa điểm Nổi bật
            </label>
        </div>

        <div class="qr-field">
            <label asp-for="Description_VI">Thuyết minh (Tiếng Việt)</label>
            <textarea asp-for="Description_VI" rows="8" placeholder="Nhập lời thuyết minh cho địa điểm này..."></textarea>
        </div>

        <div class="qr-field">
            <label>Hình ảnh minh họa</label>
            <input type="file" name="fileHinhAnh" class="form-control" accept="image/*" />
            <div class="hint">Định dạng: JPG, PNG. Khuyến nghị tỷ lệ 16:9.</div>
        </div>

        <div class="qr-form-actions">
            <button type="submit" class="btn-qr">💾 Lưu địa điểm</button>
            <a asp-action="Index" class="btn-qr-outline">← Quay lại danh sách</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
