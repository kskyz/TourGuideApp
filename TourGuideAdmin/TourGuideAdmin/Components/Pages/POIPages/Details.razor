@page "/pois/details"
@using Microsoft.EntityFrameworkCore
@using TourGuideAdmin.Models
@inject IDbContextFactory<TourGuideAdmin.Models.AppDbContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Details</PageTitle>

<h1>Details</h1>

<div>
    <h2>POI</h2>
    <hr />
    @if (poi is null)
    {
        <p><em>Loading...</em></p>
    }
    else {
        <dl class="row">
            <dt class="col-sm-2">TourId</dt>
            <dd class="col-sm-10">@poi.TourId</dd>
            <dt class="col-sm-2">Name_VI</dt>
            <dd class="col-sm-10">@poi.Name_VI</dd>
            <dt class="col-sm-2">Name_EN</dt>
            <dd class="col-sm-10">@poi.Name_EN</dd>
            <dt class="col-sm-2">Name_ZH</dt>
            <dd class="col-sm-10">@poi.Name_ZH</dd>
            <dt class="col-sm-2">Name_KO</dt>
            <dd class="col-sm-10">@poi.Name_KO</dd>
            <dt class="col-sm-2">Name_JA</dt>
            <dd class="col-sm-10">@poi.Name_JA</dd>
            <dt class="col-sm-2">Latitude</dt>
            <dd class="col-sm-10">@poi.Latitude</dd>
            <dt class="col-sm-2">Longitude</dt>
            <dd class="col-sm-10">@poi.Longitude</dd>
            <dt class="col-sm-2">TriggerRadius</dt>
            <dd class="col-sm-10">@poi.TriggerRadius</dd>
            <dt class="col-sm-2">Priority</dt>
            <dd class="col-sm-10">@poi.Priority</dd>
            <dt class="col-sm-2">Description_VI</dt>
            <dd class="col-sm-10">@poi.Description_VI</dd>
            <dt class="col-sm-2">Description_EN</dt>
            <dd class="col-sm-10">@poi.Description_EN</dd>
            <dt class="col-sm-2">Description_ZH</dt>
            <dd class="col-sm-10">@poi.Description_ZH</dd>
            <dt class="col-sm-2">Description_KO</dt>
            <dd class="col-sm-10">@poi.Description_KO</dd>
            <dt class="col-sm-2">Description_JA</dt>
            <dd class="col-sm-10">@poi.Description_JA</dd>
            <dt class="col-sm-2">IsFavorite</dt>
            <dd class="col-sm-10">@poi.IsFavorite</dd>
            <dt class="col-sm-2">ImageUrl</dt>
            <dd class="col-sm-10">@poi.ImageUrl</dd>
            <dt class="col-sm-2">LastPlayedTime</dt>
            <dd class="col-sm-10">@poi.LastPlayedTime</dd>
        </dl>
        <div>
            <a href="@($"/pois/edit?id={poi.Id}")">Edit</a> |
            <a href="@($"/pois")">Back to List</a>
        </div>
    }
</div>

@code {
    private POI? poi;

    [SupplyParameterFromQuery]
    private int Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        poi = await context.POIs.FirstOrDefaultAsync(m => m.Id == Id);

        if (poi is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }
}
